{
  "name": "harvey-mobile",
  "version": "0.1.0",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "test:contracts": "node --experimental-strip-types --test tests/contracts/contracts.test.mjs",
    "typecheck": "tsc --noEmit",
    "export:android": "expo export --platform android --output-dir dist/android",
    "export:web": "expo export --platform web --output-dir dist/web",
    "verify:flock-mailbox": "node --experimental-strip-types scripts/validate-flock-mailbox.mjs"
  },
  "dependencies": {
    "expo": "~57.0.4",
    "expo-constants": "~57.0.3",
    "expo-linking": "~57.0.2",
    "expo-router": "~57.0.4",
    "expo-status-bar": "~57.0.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.86.0",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "4.25.2",
    "react-native-web": "~0.21.0"
  },
  "devDependencies": {
    "@types/react": "~19.2.2",
    "typescript": "~6.0.3"
  }
}
